{
  "risk": {
    "vix_panic_threshold": 35.0,
    "max_position_pct": 0.20,
    "max_drawdown_limit": 0.15,
    "max_intraday_dd": 0.10,
    "single_stock_limit": 0.05
  },
  "trading": {
    "enable_paper_trading": true,
    "enable_risk_monitor": true,
    "enable_intraday_monitor": false,
    "check_interval": 60,
    "max_wait_sec": 1800,
    "poll_interval": 5,
    "market_close_cutoff_minutes": 15,
    "enable_pdt_check": true,
    "pdt_min_equity": 25000.0,
    "use_limit_orders": false,
    "limit_order_offset_pct": 0.001,
    "enable_reconcile": false,
    "rebalance_frequency": "monthly"
  },
  "weight": {
    "method": "equal",
    "max_weight": 0.20,
    "min_weight": 0.01
  },
  "universe": {
    "type": "sp500_ndx100",
    "cap": 0,
    "comment": "使用 S&P 500 + NASDAQ 100 合并股票池。type 可选 default|sp500|ndx100|sp500_ndx100|custom；custom 时填写 tickers 与 industry_map。"
  },
  "alpaca_base_url": "https://paper-api.alpaca.markets",
  "comment": "此文件为示例配置，复制为 config.json 后按需修改。API Key/Secret 请通过环境变量 ALPACA_API_KEY / ALPACA_API_SECRET 注入，不要写在此文件。"
}
